[
  // ==========================================
  // 📁 1. EXPLORER & FILE NAVIGATION (Vim Style)
  // ==========================================
  { "key": "ctrl+l", "command": "workbench.action.navigateRight", "when": "explorerViewletFocus" },
  { "key": "ctrl+l", "command": "workbench.action.focusActiveEditorGroup", "when": "sideBarFocus" },
  { "key": "shift+ctrl+e", "command": "-workbench.view.explorer" },
  { "key": "ctrl+e", "command": "workbench.action.toggleSidebarVisibility" },
  { "key": "ctrl+shift+e", "command": "workbench.files.action.focusFilesExplorer", "when": "editorTextFocus" },
  { "key": "j", "command": "list.focusDown", "when": "explorerViewletVisible && filesExplorerFocus && !inputFocus" },
  { "key": "k", "command": "list.focusUp", "when": "explorerViewletVisible && filesExplorerFocus && !inputFocus" },
  { "key": "h", "command": "list.collapse", "when": "explorerViewletVisible && filesExplorerFocus && !inputFocus" },
  { "key": "l", "command": "list.select", "when": "explorerViewletVisible && filesExplorerFocus && !inputFocus" },
  { "key": "g g", "command": "list.focusFirst", "when": "filesExplorerFocus && !inputFocus" },
  { "key": "shift+g", "command": "list.focusLast", "when": "filesExplorerFocus && !inputFocus" },
  { "key": "r", "command": "renameFile", "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus" },
  { "key": "enter", "command": "-renameFile", "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus" },
  { "key": "a", "command": "explorer.newFile", "when": "filesExplorerFocus && !inputFocus" },
  { "key": "shift+a", "command": "explorer.newFolder", "when": "filesExplorerFocus && !inputFocus" },
  { "key": "y", "command": "filesExplorer.copy", "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !inputFocus" },
  { "key": "x", "command": "filesExplorer.cut", "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !inputFocus" },
  { "key": "p", "command": "filesExplorer.paste", "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceReadonly && !inputFocus" },
  { "key": "d", "command": "deleteFile", "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceReadonly && !inputFocus" },
  { "key": "v", "command": "explorer.openToSide", "when": "explorerViewletFocus && explorerViewletVisible && !inputFocus" },

  // ==========================================
  // 📋 2. SUBMENU & LIST NAVIGATION
  // ==========================================
  { "key": "ctrl+j", "command": "selectNextSuggestion", "when": "editorTextFocus && suggestWidgetMultipleSuggestions && suggestWidgetVisible" },
  { "key": "ctrl+k", "command": "selectPrevSuggestion", "when": "editorTextFocus && suggestWidgetMultipleSuggestions && suggestWidgetVisible" },
  { "key": "ctrl+j", "command": "workbench.action.quickOpenSelectNext", "when": "inQuickOpen" },
  { "key": "ctrl+k", "command": "workbench.action.quickOpenSelectPrevious", "when": "inQuickOpen" },
  { "key": "tab", "command": "selectNextSuggestion", "when": "editorTextFocus && suggestWidgetMultipleSuggestions && suggestWidgetVisible" },
  { "key": "shift+tab", "command": "selectPrevSuggestion", "when": "editorTextFocus && suggestWidgetMultipleSuggestions && suggestWidgetVisible" },
  { "key": "tab", "command": "workbench.action.quickOpenSelectNext", "when": "inQuickOpen" },
  { "key": "shift+tab", "command": "workbench.action.quickOpenSelectPrevious", "when": "inQuickOpen" },
  { "key": "shift+tab", "command": "-acceptAlternativeSelectedSuggestion", "when": "suggestWidgetVisible && textInputFocus && textInputFocus" },
  { "key": "enter", "command": "list.select", "when": "explorerViewletVisible && filesExplorerFocus" },

  // ==========================================
  // 💻 3. TERMINAL MANAGEMENT
  // ==========================================
  { "key": "ctrl+t", "command": "workbench.action.togglePanel" },
  { "key": "ctrl+k", "command": "workbench.action.focusActiveEditorGroup", "when": "terminalFocus" },
  { "key": "ctrl+n", "command": "workbench.action.terminal.new", "when": "terminalFocus" },
  { "key": "ctrl+l", "command": "workbench.action.terminal.focusNext", "when": "terminalFocus" },
  { "key": "ctrl+h", "command": "workbench.action.terminal.focusPrevious", "when": "terminalFocus" },
  { "key": "ctrl+m", "command": "workbench.action.toggleMaximizedPanel", "when": "terminalFocus" },
  { "key": "ctrl+w", "command": "workbench.action.terminal.kill", "when": "terminalFocus" },
  { "key": "ctrl+alt+c", "command": "workbench.action.terminal.clear", "when": "terminalFocus" },
  { "key": "ctrl+shift+5", "command": "workbench.action.terminal.split", "when": "terminalFocus" },

  // ==========================================
  // 📝 4. EDITOR & LINE MANIPULATION
  // ==========================================
  { "key": "alt+j", "command": "editor.action.moveLinesDownAction", "when": "editorTextFocus && !editorReadonly" },
  { "key": "alt+k", "command": "editor.action.moveLinesUpAction", "when": "editorTextFocus && !editorReadonly" },
  { "key": "shift+alt+j", "command": "editor.action.copyLinesDownAction", "when": "editorTextFocus && !editorReadonly" },
  { "key": "shift+alt+k", "command": "editor.action.copyLinesUpAction", "when": "editorTextFocus && !editorReadonly" },
  { "key": "alt+h", "command": "workbench.action.navigateLeft", "when": "editorTextFocus" },
  { "key": "alt+l", "command": "workbench.action.navigateRight", "when": "editorTextFocus" },
  { "key": "ctrl+shift+h", "command": "workbench.action.previousEditor" },
  { "key": "ctrl+shift+l", "command": "workbench.action.nextEditor" },
  { "key": "ctrl+\\", "command": "workbench.action.splitEditor", "when": "editorTextFocus" },
  { "key": "ctrl+shift+\\", "command": "workbench.action.splitEditorDown", "when": "editorTextFocus" },
  { "key": "ctrl+alt+j", "command": "editor.action.insertCursorBelow", "when": "editorTextFocus" },
  { "key": "ctrl+alt+k", "command": "editor.action.insertCursorAbove", "when": "editorTextFocus" },
  { "key": "ctrl+shift+d", "command": "editor.action.deleteLines", "when": "editorTextFocus && !editorReadonly" },
  { "key": "ctrl+shift+j", "command": "editor.action.joinLines", "when": "editorTextFocus && !editorReadonly" },

  // ==========================================
  // 🛑 5. ERRORS & WARNINGS
  // ==========================================
  { "key": "alt+n", "command": "editor.action.marker.next", "when": "editorTextFocus" },
  { "key": "alt+p", "command": "editor.action.marker.prev", "when": "editorTextFocus" },
  { "key": "alt+enter", "command": "editor.action.quickFix", "when": "editorTextFocus && !editorReadonly" },
  { "key": "ctrl+shift+m", "command": "workbench.actions.view.problems" },

  // ==========================================
  // 🌿 6. GIT & DIFFS
  // ==========================================
  { "key": "alt+g n", "command": "editor.action.dirtydiff.next", "when": "editorTextFocus && !editorReadonly" },
  { "key": "alt+g p", "command": "editor.action.dirtydiff.previous", "when": "editorTextFocus && !editorReadonly" },
  { "key": "alt+g h", "command": "editor.action.showChangeHover", "when": "editorTextFocus && !editorReadonly" },
  { "key": "alt+g u", "command": "editor.action.dirtydiff.undo", "when": "editorTextFocus && !editorReadonly" },
  { "key": "alt+g s", "command": "git.stageChange", "when": "editorTextFocus && !editorReadonly" },

  // ==========================================
  // 📐 7. CODE FOLDING
  // ==========================================
  { "key": "alt+-", "command": "editor.fold", "when": "editorTextFocus" },
  { "key": "alt+=", "command": "editor.unfold", "when": "editorTextFocus" },
  { "key": "alt+shift+-", "command": "editor.foldAll", "when": "editorTextFocus" },
  { "key": "alt+shift+=", "command": "editor.unfoldAll", "when": "editorTextFocus" },

  // ==========================================
  // 🗂️ 8. TABS & UI COMFORT
  // ==========================================
  { "key": "ctrl+w", "command": "workbench.action.closeActiveEditor", "when": "editorTextFocus" },
  { "key": "ctrl+shift+t", "command": "workbench.action.reopenClosedEditor" },
  { "key": "ctrl+k ctrl+w", "command": "workbench.action.closeOtherEditors", "when": "editorTextFocus" },
  { "key": "alt+e", "command": "workbench.action.quickOpenPreviousRecentlyUsedEditorInGroup" },
  { "key": "alt+z", "command": "editor.action.toggleWordWrap" },
  { "key": "ctrl+b", "command": "workbench.action.toggleSidebarVisibility" },
  { "key": "ctrl+k m", "command": "workbench.action.toggleEditorWidths" },
  { "key": "ctrl+alt+n", "command": "workbench.action.moveEditorToNewWindow" },

  // ==========================================
  // 🚀 9. ZERO-MOUSE SUPERPOWERS
  // ==========================================
  { "key": "alt+i", "command": "editor.action.showHover", "when": "editorTextFocus" },
  { "key": "alt+d", "command": "editor.action.peekDefinition", "when": "editorTextFocus" },
  { "key": "alt+shift+d", "command": "editor.action.referenceSearch.trigger", "when": "editorTextFocus" },
  { "key": "alt+v", "command": "editor.action.smartSelect.expand", "when": "editorTextFocus" },
  { "key": "alt+shift+v", "command": "editor.action.smartSelect.shrink", "when": "editorTextFocus" },
  { "key": "alt+r", "command": "editor.action.rename", "when": "editorTextFocus && !editorReadonly" },
  { "key": "ctrl+/", "command": "editor.action.commentLine", "when": "editorTextFocus && !editorReadonly" },
  { "key": "shift+alt+f", "command": "editor.action.formatDocument", "when": "editorTextFocus" },
  { "key": "ctrl+z", "command": "workbench.action.toggleZenMode" },

  // ==========================================
  // 🕒 10. TIME TRAVEL & NAVIGATION
  // ==========================================
  { "key": "ctrl+u", "command": "cursorUndo", "when": "textInputFocus" },
  { "key": "ctrl+shift+u", "command": "cursorRedo", "when": "textInputFocus" },
  { "key": "alt+o", "command": "workbench.action.gotoSymbol" },
  { "key": "ctrl+shift+\\", "command": "editor.action.jumpToBracket", "when": "editorTextFocus" },
  { "key": "alt+b", "command": "breadcrumbs.focusAndSelect", "when": "breadcrumbsPossible && breadcrumbsVisible" },

  // ==========================================
  // 🛠️ 11. ADVANCED REFACTORING & INTELLISENSE
  // ==========================================
  { "key": "alt+space", "command": "editor.action.triggerParameterHints", "when": "editorTextFocus && hasSignatureHelpProvider" },
  { "key": "ctrl+shift+r", "command": "editor.action.refactor", "when": "editorTextFocus && !editorReadonly" },
  { "key": "alt+i", "command": "editor.action.focusHover", "when": "editorHoverVisible" },
  { "key": "shift+alt+o", "command": "editor.action.organizeImports", "when": "editorTextFocus && !editorReadonly" },

  // ==========================================
  // 🪟 12. WINDOW RESIZING & VIEWPORT
  // ==========================================
  { "key": "ctrl+alt+h", "command": "workbench.action.decreaseViewWidth", "when": "editorTextFocus" },
  { "key": "ctrl+alt+l", "command": "workbench.action.increaseViewWidth", "when": "editorTextFocus" },
  { "key": "ctrl+down", "command": "scrollLineDown", "when": "editorTextFocus" },
  { "key": "ctrl+up", "command": "scrollLineUp", "when": "editorTextFocus" },

  // ==========================================
  // 🪄 13. ADVANCED MULTI-OCCURRENCE
  // ==========================================
  { "key": "alt+m", "command": "editor.action.addSelectionToNextFindMatch", "when": "editorFocus" },
  { "key": "alt+shift+m", "command": "editor.action.selectHighlights", "when": "editorFocus" },
  { "key": "shift+alt+a", "command": "editor.action.blockComment", "when": "editorTextFocus && !editorReadonly" },

  // ==========================================
  // 🤖 14. AI, QUICK VIEWS & TEXT TRANSFORM
  // ==========================================
  { "key": "ctrl+i", "command": "inlineChat.start", "when": "editorTextFocus" },
  { "key": "ctrl+k ctrl+u", "command": "editor.action.transformToUppercase", "when": "editorTextFocus" },
  { "key": "ctrl+k ctrl+l", "command": "editor.action.transformToLowercase", "when": "editorTextFocus" },
  { "key": "ctrl+shift+f", "command": "workbench.view.search", "when": "!searchInputBoxFocus" },
  { "key": "ctrl+shift+g", "command": "workbench.view.scm", "when": "!scmInputReadonly" },

  // ==========================================
  // 🐞 15. DEBUGGING & TESTING (NEW)
  // ==========================================
  // 🔥 Setting and removing a breakpoint to debug the code
  { "key": "f9", "command": "editor.debug.action.toggleBreakpoint", "when": "editorTextFocus" },
  // 🔥 Run code in Debug mode (Start Debugging)
  { "key": "f5", "command": "workbench.action.debug.start", "when": "debuggersAvailable" },
  // 🔥 Jump to the next line while debugging (Step Over)
  { "key": "f10", "command": "workbench.action.debug.stepOver", "when": "inDebugMode" },
  // 🔥 Entering the function to see what it does inside (Step Into)
  { "key": "f11", "command": "workbench.action.debug.stepInto", "when": "inDebugMode" },
  // 🔥 Immediately stop the code
  { "key": "shift+f5", "command": "workbench.action.debug.stop", "when": "inDebugMode" },

  // ==========================================
  // 🔍 16. GLOBAL SEARCH & QUICK OPEN (NEW)
  // ==========================================
  // 🔥 Open any file in the project by quickly typing its name
  { "key": "ctrl+p", "command": "workbench.action.quickOpen" },
  // 🔥 Searching for any function or class in the entire project
  { "key": "ctrl+alt+o", "command": "workbench.action.showAllSymbols" },

  // ==========================================
  // 📝 17. MARKDOWN PREVIEW & FULL ZEN (NEW)
  // ==========================================
  // 🔥 Open the Markdown preview screen next to the code (excellent for formatting notes)
  { "key": "ctrl+shift+v", "command": "markdown.showPreviewToSide", "when": "editorLangId == 'markdown'" },
  // 🔥 Enlarge the current code window to fill the entire screen (for absolute focus)
  { "key": "ctrl+k z", "command": "workbench.action.toggleMaximizeEditorGroup" }
]
